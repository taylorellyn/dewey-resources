#### 1. LOAD LIBRARIES ####

library(deweyr)
library(arrow)
library(DBI)
library(duckdb)
library(tidyverse)
library(scales)
library(lubridate)


#### 2. CREDENTIALS & PATHS ####
## Store your API key in ~/.Renviron:
##   DEWEY_API_KEY=your-key-here
## Open that file with: usethis::edit_r_environ()
## Save it, then restart RStudio fully before loading.

api_key       <- Sys.getenv("DEWEY_API_KEY")
folder_id     <- "your-folder-id-here"

## Use the full absolute path to the folder containing .parquet files.
## Avoid '~' — DuckDB may not expand it correctly on all systems.
## deweyr creates a subfolder during download; confirm your path with:
##   list.files(download_path, pattern = "\\.parquet$")
download_path <- "/absolute/path/to/your/parquet/files"


#### ============================================================
#### 3. DOWNLOAD — deweyr ARGUMENT DICTIONARY
#### ============================================================
## download_dewey() downloads files from a Dewey folder to your
## local machine via UV. No manual Python setup required.
##
## ┌──────────────────────────┬────────────┬─────────────────────────────────────────────────┐
## │ Argument                 │ Type       │ Description                                     │
## ├──────────────────────────┼────────────┼─────────────────────────────────────────────────┤
## │ api_key       [REQUIRED] │ character  │ Your Dewey API key.                             │
## ├──────────────────────────┼────────────┼─────────────────────────────────────────────────┤
## │ folder_id     [REQUIRED] │ character  │ Dewey folder ID or full API URL.                │
## ├──────────────────────────┼────────────┼─────────────────────────────────────────────────┤
## │ download_path            │ character  │ Local folder for files. Defaults to             │
## │                          │            │ ./dewey-downloads in working directory.          │
## ├──────────────────────────┼────────────┼─────────────────────────────────────────────────┤
## │ python_version           │ character  │ Python version for UV. Default: "3.13".         │
## │                          │            │ Do not set to "3.14" or higher — not            │
## │                          │            │ compatible with deweypy.                        │
## ├──────────────────────────┼────────────┼─────────────────────────────────────────────────┤
## │ num_workers   [advanced] │ integer    │ Parallel download threads. Default: NULL        │
## │                          │            │ (deweypy uses 8). Adjust only if needed.        │
## ├──────────────────────────┼────────────┼─────────────────────────────────────────────────┤
## │ partition_key_after      │ character  │ Download partitions on/after this date.         │
## │               [advanced] │            │ Format: "YYYY-MM-DD".                           │
## ├──────────────────────────┼────────────┼─────────────────────────────────────────────────┤
## │ partition_key_before     │ character  │ Download partitions on/before this date.        │
## │               [advanced] │            │ Combine with partition_key_after for a window.  │
## └──────────────────────────┴────────────┴─────────────────────────────────────────────────┘
##
## First-time setup: if UV isn't installed, deweyr installs it
## automatically. Restart RStudio fully after the first run to
## ensure uvx is on your PATH before running again.


#### 3a. DOWNLOAD EXAMPLES ####

## Basic download
download_dewey(
  api_key   = api_key,
  folder_id = folder_id
)

## Date-partitioned download — recommended for monthly datasets
download_dewey(
  api_key              = api_key,
  folder_id            = folder_id,
  download_path        = download_path,
  partition_key_after  = "2025-01-01",
  partition_key_before = "2026-01-01"
)

## Download from a full Dewey URL instead of folder ID
download_dewey(
  api_key   = api_key,
  folder_id = "https://api.deweydata.io/api/v1/external/data/abc123"
)


#### ============================================================
#### 4. LOAD DATA
#### ============================================================
## deweyr includes a built-in DuckDB wrapper — preview_dewey_duck(),
## download_dewey_duck(), and read_dewey_duck() — that handles
## schema inspection, filtering, and reading without writing raw SQL.
## This is the recommended path for most users.
## Many Dewey datasets are delivered as .parquet files; we recommend
## working with parquet when available.


#### 4a. Preview schema — no download required ####
## Use preview_dewey_duck() to inspect column names and types
## before deciding what to filter and select.
## Pass limit = 0 to return only column names with no data transferred.

api_key <- Sys.getenv("DEWEY_API_KEY")
data_id <- "your-data-id-here"

## Column names only — fastest way to orient to a new dataset
colnames(preview_dewey_duck(api_key, data_id, limit = 0))

## First 10 rows
preview_dewey_duck(api_key, data_id)

## Filtered preview
preview_dewey_duck(api_key, data_id, where = "REGION = 'XX'")


#### 4b. Download, filter, and read — deweyr wrapper (recommended) ####
## download_dewey_duck() downloads with a WHERE filter and column
## selection applied — only matching data lands on disk.
## Pipe directly into read_dewey_duck() to load into R.
##
## The where argument accepts standard SQL syntax.
## The select argument accepts column names, indices, or ranges.
## The partition column is always included automatically.

data <- download_dewey_duck(
  api_key   = api_key,
  data_id   = data_id,
  partition = "DATE_RANGE_START",        # adjust to your dataset's partition column
  where     = "DATE_RANGE_START >= '2024-01-01' AND DATE_RANGE_START < '2025-01-01'",
  select    = c("AREA", "AREA_TYPE", "REGION", "YEAR", "MONTH",
                "DATE_RANGE_START", "DATE_RANGE_END",
                "STOP_COUNTS", "DEVICE_COUNTS", "MEDIAN_DWELL",
                "DAY_COUNTS", "STOPS_BY_DAY", "TOP_SAME_MONTH_BRAND")
) |>
  read_dewey_duck()

## Confirm what you loaded
nrow(data)
object.size(data) |> format(units = "MB")
glimpse(data)


