## ── PLOT 2: Daily Activity Pattern ────────────────────────────
## STOPS_BY_DAY contains one value per calendar day of the month
## (up to 31 values), not one per day-of-week.
## Format: "[0, 326, 652, ...]"
##
## We parse all day values, assign day numbers (1–31), and average
## across all CBGs to show a typical daily activity profile.
## Update ref_date to the first day of your data's month so that
## the x-axis labels show the correct dates.

ref_date <- as_date("2024-01-01")   # set to first day of your data month

stops_daily <- data_clean |>
  filter(!is.na(STOPS_BY_DAY), STOPS_BY_DAY != "") |>
  mutate(parsed = str_remove_all(STOPS_BY_DAY, "\\[|\\]")) |>
  separate(parsed,
           into    = paste0("calday_", 1:31),
           sep     = ",",
           convert = TRUE,
           fill    = "right") |>
  summarise(across(starts_with("calday_"), ~mean(.x, na.rm = TRUE))) |>
  pivot_longer(everything(), names_to = "day_key", values_to = "avg_stops") |>
  mutate(
    day_num = as.integer(str_remove(day_key, "calday_")),
    date    = ref_date + days(day_num - 1)
  ) |>
  filter(day_num <= 31, !is.na(avg_stops))

plot2 <- ggplot(stops_daily, aes(x = day_num, y = avg_stops)) +
  geom_col(fill = "#4a7c8a", alpha = 0.85, width = 0.8) +
  scale_x_continuous(
    breaks = seq(1, 31, by = 7),
    labels = format(ref_date + days(seq(0, 30, by = 7)), "%b %d")
  ) +
  scale_y_continuous(labels = label_comma()) +
  labs(
    title    = "Average Daily Stops per CBG — [Your Region], [Month Year]",
    subtitle = "Mean stops per census block group by calendar day\nAdvan Neighborhood Patterns Plus via Dewey",
    x        = NULL,
    y        = "Avg stops per CBG",
    caption  = "Source: Advan Research / Dewey Data"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title         = element_text(face = "bold"),
    plot.subtitle      = element_text(color = "grey50"),
    panel.grid.major.x = element_blank()
  )

print(plot2)
