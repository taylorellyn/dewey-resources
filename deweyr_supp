#### ============================================================
#### KEY COLUMNS — ADVAN NEIGHBORHOOD PATTERNS PLUS
##
## AREA               CBG FIPS code (12-digit). substr(AREA, 1, 5)
##                    gives county FIPS.
## AREA_TYPE          Neighborhood classification (e.g., residential,
##                    commercial). Useful for faceting visuals.
## REGION             State abbreviation (e.g., "CA", "TX").
## YEAR / MONTH       Pre-parsed date components — use instead of
##                    extracting from DATE_RANGE_START.
## DATE_RANGE_START   Start of the monthly observation period.
## STOP_COUNTS        Raw stops recorded (min. 1 min duration).
## DEVICE_COUNTS      Unique devices observed in the CBG.
## MEDIAN_DWELL       Median dwell time per stop (minutes).
## DAY_COUNTS         Device-days: one device present 3 days = 3.
## STOPS_BY_DAY       Array of daily stop counts, Sun–Sat.
##                    Format: "[120, 98, 105, 88, 142, 200, 180]"
## TOP_SAME_MONTH_BRAND  Most common POI brand visited by devices
##                    that also stopped in this CBG that month.
##
## Note: column names are all uppercase in this dataset.
## Always confirm with names(preview) on a new dataset.
#### ============================================================


#### 5. EXPLORE ####

dim(data)
summary(data)
colSums(is.na(data))
range(data$DATE_RANGE_START, na.rm = TRUE)
n_distinct(data$AREA)


#### 6. CLEAN & PREPARE ####

data_clean <- data |>
  mutate(
    DATE_RANGE_START = as_date(DATE_RANGE_START),
    DATE_RANGE_END   = as_date(DATE_RANGE_END),
    year_month       = floor_date(DATE_RANGE_START, "month"),
    county_fips      = substr(AREA, 1, 5)
  ) |>
  filter(!is.na(STOP_COUNTS), STOP_COUNTS > 0)

glimpse(data_clean)


#### ============================================================
#### 7. VISUALIZATIONS
#### ============================================================


## ── PLOT 1: Top Brands by Co-Visit Score ──────────────────────
## TOP_SAME_MONTH_BRAND is a JSON object per CBG-month where each
## key is a brand name and each value is a relative co-visit score:
##   {"Starbucks": 22, "Target": 50, "Mall": 100, ...}
## We parse the JSON across all rows, then sum scores per brand
## to surface which brands have the broadest neighborhood presence.
## install.packages("jsonlite") if not already installed.

library(jsonlite)

brand_parsed <- data_clean |>
  filter(!is.na(TOP_SAME_MONTH_BRAND),
         TOP_SAME_MONTH_BRAND != "",
         TOP_SAME_MONTH_BRAND != "{}") |>
  mutate(row_id = row_number()) |>
  rowwise() |>
  mutate(brands = list(
    tryCatch(
      as.data.frame(t(unlist(fromJSON(TOP_SAME_MONTH_BRAND)))),
      error = function(e) NULL
    )
  )) |>
  ungroup() |>
  filter(!sapply(brands, is.null)) |>
  select(row_id, brands) |>
  unnest(brands) |>
  pivot_longer(-row_id, names_to = "brand", values_to = "score") |>
  mutate(score = as.numeric(score)) |>
  filter(!is.na(score))

brand_summary <- brand_parsed |>
  group_by(brand) |>
  summarise(total_score = sum(score, na.rm = TRUE), .groups = "drop") |>
  slice_max(total_score, n = 15)

plot1 <- ggplot(brand_summary,
                aes(x = reorder(brand, total_score), y = total_score)) +
  geom_col(fill = "#c8572a", alpha = 0.85, width = 0.7) +
  coord_flip() +
  scale_y_continuous(labels = label_comma()) +
  labs(
    title    = "Top 15 Brands by Co-Visit Score — [Your Region], [Year]",
    subtitle = "Sum of same-month co-visit scores across all CBGs\nAdvan Neighborhood Patterns Plus via Dewey",
    x        = NULL,
    y        = "Total co-visit score",
    caption  = "Source: Advan Research / Dewey Data"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title         = element_text(face = "bold"),
    plot.subtitle      = element_text(color = "grey50", size = 10),
    panel.grid.major.y = element_blank()
  )

print(plot1)
# ggsave("plot1_top_brands.png", plot1, width = 8, height = 6, dpi = 150)


